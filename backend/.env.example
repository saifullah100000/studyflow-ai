NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:5173

DATABASE_URL="postgresql://studyflow:replace_this_password@localhost:5432/studyflow_db?schema=public"
BCRYPT_ROUNDS=10

JWT_SECRET=replace_with_a_secure_random_secret
JWT_EXPIRES_IN_SECONDS=3600
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=120000

GEMINI_MAX_ATTEMPTS=3
GEMINI_RETRY_BASE_DELAY_MS=800

N8N_ENABLED=true
N8N_WEBHOOK_URL=http://localhost:5678/webhook/studyflow-generation
N8N_WEBHOOK_SECRET=replace_with_a_secure_webhook_secret
N8N_TIMEOUT_MS=10000

N8N_CALLBACK_SECRET=replace_with_a_secure_callback_secret
N8N_TIMEOUT_MS=180000