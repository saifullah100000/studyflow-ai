generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EducationLevel {
  SCHOOL
  COLLEGE
  UNIVERSITY
  PROFESSIONAL
}

enum GenerationLanguage {
  ENGLISH
  URDU
}

enum NotesLength {
  SHORT
  MEDIUM
  LONG
}

enum QuizQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum FileKind {
  SOURCE
  GENERATED_PDF
  GENERATED_DOCX
  OTHER
}

enum DeliveryChannel {
  WHATSAPP
  EMAIL
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(USER)

  notes          Note[]
  generationJobs GenerationJob[]
  files          File[]
  deliveryLogs   DeliveryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Note {
  id      String  @id @default(uuid())
  title   String
  topic   String?
  summary String? @db.Text
  content String? @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  generationJobId String?        @unique
  generationJob   GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  sections     NoteSection[]
  flashcards   Flashcard[]
  quizzes      Quiz[]
  files        File[]
  deliveryLogs DeliveryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
}

model NoteSection {
  id       String @id @default(uuid())
  heading  String
  content  String @db.Text
  position Int

  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([noteId, position])
  @@index([noteId])
}

model GenerationJob {
  id           String           @id @default(uuid())
  topic        String
  subject      String           @default("General")
  prompt       String?          @db.Text
  status       GenerationStatus @default(PENDING)
  errorMessage String?          @db.Text

  educationLevel           EducationLevel     @default(UNIVERSITY)
  language                 GenerationLanguage @default(ENGLISH)
  notesLength              NotesLength        @default(MEDIUM)
  numberOfMcqs             Int                @default(10)
  numberOfFlashcards       Int                @default(10)
  includePracticalExamples Boolean            @default(true)
  sendToWhatsapp           Boolean            @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  inputFileId String?
  inputFile   File?   @relation("GenerationInputFile", fields: [inputFileId], references: [id], onDelete: SetNull)

  note         Note?
  deliveryLogs DeliveryLog[]

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([inputFileId])
  @@index([createdAt])
}

model Flashcard {
  id       String @id @default(uuid())
  front    String @db.Text
  back     String @db.Text
  position Int

  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([noteId, position])
  @@index([noteId])
}

model Quiz {
  id          String  @id @default(uuid())
  title       String
  description String? @db.Text
  position    Int     @default(0)

  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  questions QuizQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([noteId, position])
  @@index([noteId])
}

model QuizQuestion {
  id            String           @id @default(uuid())
  question      String           @db.Text
  type          QuizQuestionType @default(MULTIPLE_CHOICE)
  options       String[]         @default([])
  correctAnswer String           @db.Text
  explanation   String?          @db.Text
  position      Int

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, position])
  @@index([quizId])
}

model File {
  id           String   @id @default(uuid())
  originalName String
  storageKey   String   @unique
  mimeType     String
  sizeBytes    Int
  kind         FileKind @default(SOURCE)
  publicUrl    String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  noteId String?
  note   Note?   @relation(fields: [noteId], references: [id], onDelete: SetNull)

  inputForJobs GenerationJob[] @relation("GenerationInputFile")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([noteId])
}

model DeliveryLog {
  id                String          @id @default(uuid())
  channel           DeliveryChannel @default(WHATSAPP)
  status            DeliveryStatus  @default(PENDING)
  recipient         String
  providerMessageId String?
  errorMessage      String?         @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  noteId String?
  note   Note?   @relation(fields: [noteId], references: [id], onDelete: SetNull)

  generationJobId String?
  generationJob   GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, channel, status])
  @@index([noteId])
  @@index([generationJobId])
  @@index([providerMessageId])
}
