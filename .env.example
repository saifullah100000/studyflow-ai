# Application
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3000/api

# Backend
PORT=3000
API_PREFIX=api

# PostgreSQL
POSTGRES_USER=studyflow
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=studyflow_db
DATABASE_URL=postgresql://studyflow:change_this_password@localhost:5432/studyflow_db

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook/generate-notes
N8N_CALLBACK_SECRET=replace_with_shared_secret

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=studyflow-pdfs
R2_PUBLIC_URL=https://your-storage-domain.example.com